@model IEnumerable<Proposal.Models.Equipment>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-info fw-bold">
            <i class="bi bi-cpu-fill me-2"></i>搜尋結果：
            <span class="text-white">"@ViewData["SearchTerm"]"</span>
        </h2>
        <a href="/" class="btn btn-outline-info btn-sm">返回首頁</a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center p-5 rounded" style="background: rgba(255,255,255,0.05); border: 1px dashed #666;">
            <i class="bi bi-search fs-1 text-secondary mb-3 d-block"></i>
            <h4 class="text-secondary">找不到相關裝備</h4>
            <p class="text-muted">請確認您的裝備庫中是否已有該名稱的裝備。</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 bg-dark text-white border-secondary shadow-lg" style="transition: transform 0.2s;">
                        <div class="card-body">
                            <h5 class="card-title text-warning fw-bold">@item.Name</h5>
                            <hr class="border-secondary">
                            <ul class="list-unstyled">
                                <li class="d-flex justify-content-between">
                                    <span class="text-muted">生命值 (HP):</span>
                                    <span class="text-danger fw-bold">@item.HP</span>
                                </li>
                                <li class="d-flex justify-content-between">
                                    <span class="text-muted">物理攻擊:</span>
                                    <span class="text-warning fw-bold">@item.Attack</span>
                                </li>
                                <li class="d-flex justify-content-between">
                                    <span class="text-muted">裝備價格:</span>
                                    <span class="text-success fw-bold">@item.Price</span>
                                </li>
                            </ul>
                        </div>
                        <div class="card-footer bg-transparent border-secondary text-center">
                            <a href="/Calculator/Index" class="btn btn-primary btn-sm w-100">
                                <i class="bi bi-calculator me-1"></i>帶入計算機
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .card:hover {
        transform: translateY(-5px);
        border-color: #0dcaf0 !important;
    }
</style>