@model IEnumerable<Proposal.Models.Equipment>

@{
    ViewData["Title"] = "裝備管理";
}

<div class="container-fluid px-4">
    <div class="d-flex flex-column flex-xl-row justify-content-between align-items-xl-center mb-4 gap-3">
        <h2 class="text-info m-0 text-nowrap"><i class="bi bi-shield-sword me-2"></i>裝備管理庫</h2>

        <form asp-action="Index" method="get" class="d-flex flex-grow-1 mx-xl-3" style="max-width: 400px;">
            <div class="input-group">
                <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control text-bg-dark border-secondary" placeholder="輸入裝備名稱查詢..." aria-label="搜尋">
                <button class="btn btn-outline-info" type="submit"><i class="bi bi-search"></i> 查詢</button>
        
                @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary" title="清除搜尋"><i class="bi bi-x-lg"></i></a>
                }
            </div>
        </form>

        <div class="d-flex gap-2 flex-wrap">
            <div class="btn-group me-2">
                <span class="btn btn-outline-secondary disabled border-info text-info" id="selectedCount">已選 0 / 6</span>
                <button type="button" class="btn btn-outline-info" onclick="openLoadoutModal()">
                    <i class="bi bi-box-seam me-1"></i> 儲存組合
                </button>
            </div>

            <a asp-action="ExportExcel" class="btn btn-outline-success">
                <i class="bi bi-file-earmark-excel"></i> 匯出 Excel
            </a>
            <button type="button" class="btn btn-outline-warning" data-bs-toggle="modal" data-bs-target="#importModal">
                <i class="bi bi-upload"></i> 匯入資料
            </button>
            <a asp-action="Create" class="btn btn-info text-white fw-bold shadow-sm">
                <i class="bi bi-plus-circle me-1"></i> 鍛造新裝備
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show text-bg-success border-0" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show text-bg-danger border-0" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm border-secondary bg-dark">
        <div class="card-body p-0">
            <table class="table table-dark table-hover table-striped mb-0 text-center align-middle">
                <thead class="table-active">
                    <tr>
                        <th style="width: 50px;">選取</th>
                        <th>ID</th>
                        <th>裝備名稱</th>
                        <th>血量 (HP)</th>
                        <th>物攻 / 魔攻</th>
                        <th>物防 / 魔防</th>
                        <th>價錢</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr class="equipment-row">
                                <td>
                                    <input type="checkbox" class="form-check-input eq-checkbox"
                                           value="@item.Id"
                                           data-name="@item.Name"
                                           onchange="updateSelectionUI()">
                                </td>
                                <td>@item.Id</td>
                                <td class="fw-bold text-info">@item.Name</td>
                                <td class="text-danger">@item.HP</td>
                                <td>@item.Attack / <span class="text-primary">@item.MagicAttack</span></td>
                                <td>@item.PhysicalDefense / <span class="text-primary">@item.MagicDefense</span></td>
                                <td class="text-warning"><i class="bi bi-coin me-1"></i>@item.Price</td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-light me-1">
                                        <i class="bi bi-pencil"></i> 修改
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('確定要銷毀這個裝備嗎？這可是無法復原的哦！');">
                                        <i class="bi bi-trash"></i> 刪除
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                                目前資料庫中沒有任何裝備資料哦！
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="modal fade" id="loadoutSaveModal" tabindex="-1" data-bs-theme="dark">
        <div class="modal-dialog">
            <div class="modal-content border-info shadow-lg">
                <div class="modal-header bg-info text-dark">
                    <h5 class="modal-title fw-bold"><i class="bi bi-box-seam-fill me-2"></i>儲存裝備組合</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-4">
                        <label class="form-label text-info">組合名稱</label>
                        <input type="text" id="loadoutName" class="form-control border-info text-white" placeholder="例如：鳴潮守岸人專屬套裝">
                    </div>
                    <h6 class="text-secondary small text-uppercase mb-3">即將儲存的裝備清單：</h6>
                    <div id="selectedItemsPreview" class="d-flex flex-wrap gap-2">
                    </div>
                </div>
                <div class="modal-footer border-top border-secondary">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                    <button type="button" class="btn btn-info text-dark fw-bold" onclick="submitLoadout()">確認儲存</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="importModal" tabindex="-1" data-bs-theme="dark">
    </div>
</div>

<style>
    /* 選中列的高亮效果 */
    .equipment-row.selected-row {
        background-color: rgba(13, 202, 240, 0.1) !important;
        border-left: 4px solid #0dcaf0;
    }
    
    .eq-checkbox {
        width: 1.2rem;
        height: 1.2rem;
        cursor: pointer;
    }

        .eq-checkbox:checked {
            background-color: #0dcaf0;
            border-color: #0dcaf0;
        }
</style>

<script>
    // 更新介面顯示與勾選限制
    function updateSelectionUI() {
        const checkboxes = document.querySelectorAll('.eq-checkbox:checked');
        const count = checkboxes.length;
        const countBadge = document.getElementById('selectedCount');
        
        countBadge.innerText = `已選 ${count} / 6`;
        
        // 變更 Badge 顏色提示
        if(count === 6) countBadge.classList.replace('text-info', 'text-warning');
        else countBadge.classList.replace('text-warning', 'text-info');

        // 限制最多 6 個
        document.querySelectorAll('.eq-checkbox').forEach(cb => {
            if (count >= 6 && !cb.checked) cb.disabled = true;
            else cb.disabled = false;

            // 切換整列的背景色
            const row = cb.closest('tr');
            if(cb.checked) row.classList.add('selected-row');
            else row.classList.remove('selected-row');
        });
    }

    // 開啟儲存視窗
    function openLoadoutModal() {
        const selected = document.querySelectorAll('.eq-checkbox:checked');
        if (selected.length === 0) {
            alert('請至少勾選一件裝備！');
            return;
        }

        const preview = document.getElementById('selectedItemsPreview');
        preview.innerHTML = '';
        
        selected.forEach(cb => {
            const span = document.createElement('span');
            span.className = 'badge border border-info text-info p-2';
            span.innerHTML = `<i class="bi bi-tag me-1"></i>${cb.getAttribute('data-name')}`;
            preview.appendChild(span);
        });

        new bootstrap.Modal(document.getElementById('loadoutSaveModal')).show();
    }

    // 送出至後端
    async function submitLoadout() {
        const name = document.getElementById('loadoutName').value.trim();
        if (!name) {
            alert('請輸入組合名稱！');
            return;
        }

        const ids = Array.from(document.querySelectorAll('.eq-checkbox:checked'))
                         .map(cb => parseInt(cb.value));

        const formData = new FormData();
        formData.append('loadoutName', name);
        ids.forEach(id => formData.append('equipmentIds', id));

        try {
            // 注意：這裡的路徑要對應你的 Controller 名稱
            const response = await fetch('/Equipment/SaveLoadout', {
                method: 'POST',
                body: formData
            });

            const result = await response.json();
            if (result.success) {
                alert('🎉 ' + result.message);
                location.reload();
            } else {
                alert('❌ ' + result.message);
            }
        } catch (error) {
            console.error('Error:', error);
            alert('系統錯誤，請檢查網路。');
        }
    }
</script>