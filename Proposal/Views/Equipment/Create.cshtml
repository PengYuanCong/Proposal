@model Proposal.Models.Equipment

@{
    ViewData["Title"] = "新增裝備";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-secondary bg-dark text-light">
                <div class="card-header border-secondary bg-transparent py-3">
                    <h4 class="mb-0 text-primary"><i class="bi bi-hammer me-2"></i>鍛造新裝備</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label text-info fw-bold">裝備名稱</label>
                            <input asp-for="Name" class="form-control text-bg-dark border-secondary" required placeholder="例如：精靈的木盾" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="HP" class="form-label text-danger">增加血量 (HP)</label>
                                <input asp-for="HP" type="number" class="form-control text-bg-dark border-secondary" value="0" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Price" class="form-label text-warning">裝備價格</label>
                                <input asp-for="Price" type="number" class="form-control text-bg-dark border-secondary" value="0" />
                            </div>
                        </div>

                        <div class="row border border-secondary rounded p-2 mb-3 mx-0 bg-opacity-10 bg-white">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Attack" class="form-label">⚔️ 物理攻擊力</label>
                                <input asp-for="Attack" type="number" class="form-control text-bg-dark border-secondary" value="0" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="MagicAttack" class="form-label text-primary">✨ 魔法攻擊力</label>
                                <input asp-for="MagicAttack" type="number" class="form-control text-bg-dark border-secondary" value="0" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="PhysicalDefense" class="form-label text-warning">🛡️ 物理防禦力</label>
                                <input asp-for="PhysicalDefense" type="number" class="form-control text-bg-dark border-secondary" value="0" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="MagicDefense" class="form-label text-info">🔮 魔法防禦力</label>
                                <input asp-for="MagicDefense" type="number" class="form-control text-bg-dark border-secondary" value="0" />
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary">取消返回</a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save me-1"></i> 儲存裝備
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>