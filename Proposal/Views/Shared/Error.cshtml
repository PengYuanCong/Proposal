@model ErrorViewModel
@{
    ViewData["Title"] = "系統錯誤";
}

<div class="text-center mt-5 p-5 bg-dark rounded border border-danger">
    <h1 class="text-danger fw-bold">⚠️ 系統發生波動</h1>
    <p class="text-white">工程師正在修復數據擾動中...</p>
    @if (Model?.ShowRequestId ?? false)
    {
        <code class="text-secondary small">錯誤編號: @Model.RequestId</code>
    }
    <div class="mt-4">
        <a href="/" class="btn btn-outline-info">回到安全區域 (首頁)</a>
    </div>
</div>
