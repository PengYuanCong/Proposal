@{
    ViewData["Title"] = "遊戲數值計算";
}

<h2 class="text-info mb-4"><i class="bi bi-calculator me-2"></i>遊戲數值公式計算</h2>

<div class="row mb-4 p-4 rounded shadow-sm" style="background-color: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255,255,255,0.1);">
    <div class="col-md-4 mb-3 mb-md-0">
        <label class="form-label text-info fw-bold">1. 選擇計算公式</label>
        <select id="formulaType" class="form-select text-bg-dark border-secondary" onchange="changeInputs()">
            <option value="">-- 請先選擇要計算什麼 --</option>
            <option value="cp">裝備性價比 (CP值)</option>
            <option value="dr">減傷百分比</option>
            <option value="ehp">有效生命值 (EHP)</option>
        </select>
    </div>

    <div class="col-md-8">
        <label class="form-label text-warning fw-bold"><i class="bi bi-lightning-fill me-1"></i>2. 懶得輸入？從裝備庫/組合快載</label>
        <div class="input-group">
            <span class="input-group-text text-bg-dark border-secondary">單件</span>
            <select id="equipmentSelector" class="form-select text-bg-dark border-secondary">
                <option value="">-- 選擇單件裝備 --</option>
                @if (ViewBag.EquipmentList != null)
                {
                    foreach (var item in ViewBag.EquipmentList)
                    {
                        <option value="@item.Id">@item.Name</option>
                    }
                }
            </select>
            
            <span class="input-group-text text-bg-dark border-secondary">組合</span>
            <select id="loadoutSelector" class="form-select text-bg-dark border-secondary">
                <option value="">-- 選擇裝備組合 --</option>
                @if (ViewBag.LoadoutList != null)
                {
                    foreach (var lo in (List<Proposal.Models.Loadout>)ViewBag.LoadoutList)
                    {
                        <option value="@lo.Id">@lo.LoadoutName</option>
                    }
                }
            </select>
            
            <button type="button" id="btnLoadData" class="btn btn-warning fw-bold" onclick="handleDataLoading()">
                <i class="bi bi-download"></i> 帶入
            </button>
        </div>
    </div>
</div>

<div id="input-fields" class="mb-4 p-4 rounded" style="min-height: 150px; background-color: rgba(0,0,0,0.2); border: 1px dashed rgba(255,255,255,0.2);">
    <div class="text-center text-secondary mt-3">
        <i class="bi bi-arrow-up-circle fs-3 d-block mb-2"></i>請先從上方選擇要計算的公式
    </div>
</div>

<button type="button" id="btnCalculate" class="btn btn-primary w-100 btn-lg fw-bold mb-4 shadow" style="display:none;">
    <i class="bi bi-play-circle-fill me-2"></i>開始計算
</button>

<div id="resultArea" class="p-4 text-center rounded shadow d-none" style="border: 1px solid #20c997; background-color: rgba(32, 201, 151, 0.1);">
    <h5 class="text-success mb-3"><i class="bi bi-check-circle-fill me-2"></i>計算結果</h5>
    <h2 id="resultValue" class="text-white fw-bold mb-0" style="letter-spacing: 1px;">--</h2>
</div>

@section Scripts {
    <script>
        // ======= A. 切換公式 (保持原樣) =======
        function changeInputs() {
            var type = document.getElementById("formulaType").value;
            var container = document.getElementById("input-fields");
            var btn = document.getElementById("btnCalculate");
            var resultArea = document.getElementById("resultArea");
            
            container.innerHTML = "";
            resultArea.classList.add('d-none');
            btn.style.display = type === "" ? "none" : "block";

            if (type === "cp") {
                container.innerHTML = `
                    <div class="mb-3"><label class="form-label text-light">屬性總價值</label><input type="number" step="0.01" class="form-control text-bg-dark border-secondary" id="input_param1" required></div>
                    <div class="mb-3"><label class="form-label text-warning">💰 裝備總價格</label><input type="number" step="0.01" class="form-control text-bg-dark border-secondary" id="input_param2" required></div>`;
            } else if (type === "dr") {
                container.innerHTML = `
                    <div class="row">
                        <div class="col-6 mb-3"><label class="form-label" style="color: #6ea8fe;">🛡️ 物理防禦</label><input type="number" step="0.01" class="form-control text-bg-dark border-secondary" id="input_param1" required></div>
                        <div class="col-6 mb-3"><label class="form-label text-info">✨ 魔法防禦</label><input type="number" step="0.01" class="form-control text-bg-dark border-secondary" id="input_param2" required></div>
                    </div>`;
            } else if (type === "ehp") {
                container.innerHTML = `
                    <div class="mb-3"><label class="form-label text-danger">❤️ 基礎生命值 (HP)</label><input type="number" step="0.01" class="form-control text-bg-dark border-secondary" id="input_param1" required></div>
                    <div class="row">
                        <div class="col-6 mb-3"><label class="form-label" style="color: #6ea8fe;">🛡️ 物理防禦</label><input type="number" step="0.01" class="form-control text-bg-dark border-secondary" id="input_param2" required></div>
                        <div class="col-6 mb-3"><label class="form-label text-info">✨ 魔法防禦</label><input type="number" step="0.01" class="form-control text-bg-dark border-secondary" id="input_param3" required></div>
                    </div>`;
            } else {
                container.innerHTML = `<div class="text-center text-secondary mt-3"><i class="bi bi-arrow-up-circle fs-3 d-block mb-2"></i>請先從上方選擇要計算的公式</div>`;
            }
        }

        // ======= B. 帶入資料 (邏輯分流：單件 vs 組合) =======
        function handleDataLoading() {
            const formulaType = document.getElementById("formulaType").value;
            const eqId = document.getElementById('equipmentSelector').value;
            const loadoutId = document.getElementById('loadoutSelector').value;
            
            if (!formulaType) { alert('請先選擇左方的「計算公式」！'); return; }
            if (!eqId && !loadoutId) { alert('請從「單件」或「組合」中擇一選取！'); return; }

            const btn = document.getElementById('btnLoadData');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
            btn.disabled = true;

            // 判斷請求網址 (如果有選組合，優先抓組合)
            let fetchUrl = loadoutId ? `/Calculator/GetLoadoutStats?loadoutId=${loadoutId}` : `/Equipment/GetEquipmentDetails/${eqId}`;

            fetch(fetchUrl)
                .then(res => res.json())
                .then(data => {
                    if (data) {
                        // 統一處理資料名稱 (單件 API 回傳 physicalDefense, 組合 API 回傳 pDef)
                        const hp = data.hp;
                        const pDef = data.physicalDefense || data.pDef;
                        const mDef = data.magicDefense || data.mDef;
                        const atk = data.attack;
                        const mAtk = data.magicAttack;
                        const price = data.price;

                        if (formulaType === "cp") {
                            document.getElementById('input_param1').value = hp + atk + mAtk + pDef + mDef;
                            document.getElementById('input_param2').value = price;
                        } else if (formulaType === "dr") {
                            document.getElementById('input_param1').value = pDef;
                            document.getElementById('input_param2').value = mDef;
                        } else if (formulaType === "ehp") {
                            document.getElementById('input_param1').value = hp;
                            document.getElementById('input_param2').value = pDef;
                            document.getElementById('input_param3').value = mDef;
                        }
                    }
                })
                .catch(err => console.error(err))
                .finally(() => { btn.innerHTML = originalText; btn.disabled = false; });
        }

        // ======= C. 執行計算與自動存檔 (保持原樣) =======
        document.getElementById('btnCalculate').addEventListener('click', function() {
            const type = document.getElementById("formulaType").value;
            const typeText = document.getElementById("formulaType").options[document.getElementById("formulaType").selectedIndex].text;
            
            const p1 = parseFloat(document.getElementById('input_param1')?.value) || 0;
            const p2 = parseFloat(document.getElementById('input_param2')?.value) || 0;
            const p3 = parseFloat(document.getElementById('input_param3')?.value) || 0;

            let result = "";
            if (type === "cp") {
                if(p2 === 0) { alert("裝備價格不能為 0！"); return; }
                result = `CP 值：${(p1 / p2).toFixed(2)}`;
            } else if (type === "dr") {
                result = `物理減傷：${(p1 / (p1 + 100) * 100).toFixed(1)}% <br> 魔法減傷：${(p2 / (p2 + 100) * 100).toFixed(1)}%`;
            } else if (type === "ehp") {
                result = `面對物理傷害 EHP：${(p1 * (1 + p2 / 100)).toFixed(0)} <br> 面對魔法傷害 EHP：${(p1 * (1 + p3 / 100)).toFixed(0)}`;
            }

            document.getElementById('resultValue').innerHTML = result;
            document.getElementById('resultArea').classList.remove('d-none');

            let inputsString = (type === "cp") ? `總價值: ${p1} , 價格: ${p2}` : (type === "dr") ? `物防: ${p1} , 魔防: ${p2}` : `HP: ${p1} , 物防: ${p2} , 魔防: ${p3}`;

            fetch('/Calculator/SaveRecord', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({
                    'type': typeText,
                    'inputs': inputsString,
                    'result': result.replace('<br>', ' | ')
                })
            });
        });

        window.onload = changeInputs;
    </script>
}