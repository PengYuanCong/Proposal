@model IEnumerable<Proposal.Models.VideoItem>

<style>
    .media-container {
        display: flex;
        height: 80vh;
        gap: 20px;
        margin-top: 20px;
    }
    /* 左側搜尋清單 */
    .video-sidebar {
        flex: 1;
        background: rgba(33, 37, 41, 0.9);
        border-radius: 15px;
        padding: 15px;
        overflow-y: auto;
    }
    .video-item {
        cursor: pointer;
        padding: 10px;
        margin-bottom: 10px;
        border-bottom: 1px solid #444;
        transition: 0.3s;
    }
    .video-item:hover { background: rgba(0, 123, 255, 0.2); }

    /* 右側播放與上傳區 */
    .main-player-area {
        flex: 3;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }
    .video-viewport {
        width: 100%;
        background: #000;
        aspect-ratio: 16 / 9;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    /* 拖曳上傳區 */
    .drop-zone {
        border: 2px dashed #007bff;
        border-radius: 15px;
        padding: 30px;
        text-align: center;
        background: rgba(255, 255, 255, 0.05);
        transition: 0.3s;
    }
    .drop-zone.active { background: rgba(0, 123, 255, 0.2); }
</style>

<div class="container-fluid">
    <div class="media-container">
    <div class="video-sidebar">
        <h5 class="text-white mb-3">精彩操作搜尋</h5>
        <div class="input-group mb-3">
            <input type="text" id="ytSearchInput" class="form-control" placeholder="輸入關鍵字...">
            <button class="btn btn-primary" onclick="handleSearch()">搜尋</button>
        </div>
        
        <div id="videoList">
            <p class="text-secondary small">搜尋後的影片會出現在這裡...</p>
        </div>
    </div>

    <div class="main-player-area">
        <div class="video-viewport" id="playerContainer">
            <div class="text-center">
                <i class="bi bi-play-btn fs-1 text-secondary"></i>
                <p class="text-secondary">點擊左側影片進行預覽</p>
            </div>
        </div>
        <div id="dropZone" class="drop-zone text-white">
            <p>拖曳本地檔案至此播放</p>
        </div>
    </div>
</div>

<script>
    // 1. YouTube 搜尋邏輯 (正式環境：呼叫後端 API)
    async function handleSearch() {
        try {
            const query = document.getElementById('ytSearchInput').value;
            if (!query) return;

            const videoList = document.getElementById('videoList');
            videoList.innerHTML = '<div class="text-white">搜尋中...</div>';

            // 呼叫後端 MediaController 的 GetYouTubeVideos
            const response = await fetch(`/Media/GetYouTubeVideos?query=${encodeURIComponent(query)}`);
            
            if (!response.ok) throw new Error('API 請求失敗');

            const data = await response.json();
            videoList.innerHTML = ''; // 清空狀態文字
            
            // 解析 YouTube API 回傳的資料並生成左側清單
            data.items.forEach(item => {
                const videoId = item.id.videoId;
                const title = item.snippet.title;
                const thumb = item.snippet.thumbnails.default.url;
                const channel = item.snippet.channelTitle;

                const div = document.createElement('div');
                div.className = 'video-item text-white';
                div.innerHTML = `
                    <div class="d-flex align-items-center">
                        <img src="${thumb}" style="width:80px; margin-right:10px; border-radius:5px;">
                        <div>
                            <div style="font-size:0.85rem; line-height:1.2;">${title}</div>
                            <small class="text-secondary">${channel}</small>
                        </div>
                    </div>
                `;
                // 點擊後右側播放
                div.onclick = () => playVideo(videoId);
                videoList.appendChild(div);
            });

        } catch (error) {
            console.error('Fetch Error:', error);
            document.getElementById('videoList').innerHTML = '<div class="text-danger">搜尋失敗，請檢查 API 設定</div>';
        }
    }

    // 2. 右側影片播放器邏輯
    function playVideo(videoId) {
        const container = document.getElementById('playerContainer');
        container.innerHTML = `
            <iframe width="100%" height="100%" 
                src="https://www.youtube.com/embed/${videoId}?autoplay=1" 
                frameborder="0" allow="autoplay; encrypted-media" allowfullscreen>
            </iframe>`;
    }

    // 3. 拖曳上傳與本地播放邏輯
    const dropZone = document.getElementById('dropZone');
    const fileInput = document.getElementById('fileInput');

    if (dropZone) {
        dropZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropZone.classList.add('active');
        });

        dropZone.addEventListener('dragleave', () => dropZone.classList.remove('active'));

        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropZone.classList.remove('active');
            const file = e.dataTransfer.files[0];
            handleVideoFile(file);
        });
    }

    if (fileInput) {
        fileInput.addEventListener('change', (e) => {
            handleVideoFile(e.target.files[0]);
        });
    }

    function handleVideoFile(file) {
        if (file && file.type.startsWith('video/')) {
            const url = URL.createObjectURL(file);
            const container = document.getElementById('playerContainer');
            container.innerHTML = `<video width="100%" height="100%" controls autoplay><source src="${url}" type="${file.type}"></video>`;
            
            // 加入左側清單提醒
            const videoList = document.getElementById('videoList');
            const newItem = document.createElement('div');
            newItem.className = 'video-item text-info';
            newItem.innerText = `[本地匯入] ${file.name}`;
            videoList.prepend(newItem);
        }
    }
</script>