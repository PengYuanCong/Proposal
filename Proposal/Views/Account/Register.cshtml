@{
    Layout = null; // 一樣不要套用左側選單
}

<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>註冊新帳號 - 面試專案</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    
    <style>
        body {
            background: linear-gradient(135deg, #0f2027 0%, #203a43 50%, #2c5364 100%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .login-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 15px;
            box-shadow: 0 15px 25px rgba(0,0,0,0.5);
            padding: 40px;
            width: 100%;
            max-width: 450px;
            color: white;
        }
        .login-card input {
            background: rgba(255, 255, 255, 0.1);
            border: none;
            color: white;
        }
        .login-card input:focus {
            background: rgba(255, 255, 255, 0.2);
            color: white;
            box-shadow: none;
            border: 1px solid #20c997; /* 註冊頁面改用薄荷綠點綴 */
        }
    </style>
</head>
<body>

    <a href="/" class="btn btn-link text-info text-decoration-none position-absolute top-0 start-0 m-4">
        <i class="bi bi-arrow-left-circle fs-3 align-middle me-2"></i>
        <span class="fs-5 align-middle fw-bold">返回主畫面</span>
    </a>

    <div class="login-card">
        <div class="text-center mb-4">
            <i class="bi bi-person-plus-fill text-success" style="font-size: 3rem;"></i>
            <h3 class="mt-2 fw-bold">建立新帳號</h3>
            <p class="text-light opacity-75">加入 Peng's System</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2 text-center" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-1"></i> @ViewBag.Error
            </div>
        }

        <form asp-action="Register" method="post">
            <div class="mb-3">
                <label class="form-label text-success"><i class="bi bi-person me-1"></i>希望的使用者帳號</label>
                <input type="text" name="username" class="form-control form-control-lg" required autocomplete="off" placeholder="例如：NewUser123">
            </div>
            <div class="mb-3">
                <label class="form-label text-success"><i class="bi bi-key me-1"></i>設定密碼</label>
                <input type="password" name="password" class="form-control form-control-lg" required placeholder="請輸入密碼">
            </div>
            <div class="mb-4">
                <label class="form-label text-success"><i class="bi bi-check2-all me-1"></i>確認密碼</label>
                <input type="password" name="confirmPassword" class="form-control form-control-lg" required placeholder="請再次輸入密碼">
            </div>
            <button type="submit" class="btn btn-success w-100 btn-lg text-white fw-bold mb-3">
                立即註冊 <i class="bi bi-arrow-right-circle ms-1"></i>
            </button>
            
            <div class="text-center">
                <span class="text-white-50">已經有帳號了嗎？</span>
                <a asp-action="Login" class="text-info text-decoration-none fw-bold ms-1">前往登入</a>
            </div>
        </form>
    </div>

</body>
</html>