@{
    ViewData["Title"] = "行事曆管理";
}

<div class="container mt-4">
    <div class="card bg-dark border-secondary shadow">
        <div class="card-body">
            <div id="calendar"></div>
        </div>
    </div>
</div>

<div class="modal fade" id="eventModal" tabindex="-1" data-bs-theme="dark">
    <div class="modal-dialog">
        <div class="modal-content border-secondary">
            <div class="modal-header">
                <h5 class="modal-title text-primary">新增排程</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">行程名稱</label>
                    <input type="text" id="eventTitle" class="form-control" placeholder="輸入行程內容...">
                </div>
                <div class="mb-3">
                    <label class="form-label">開始時間</label>
                    <input type="datetime-local" id="eventStart" class="form-control">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary" onclick="saveEvent()">確認儲存</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js"></script>
    <script>
        var calendar;
        document.addEventListener('DOMContentLoaded', function() {
        var calendarEl = document.getElementById('calendar');
        calendar = new FullCalendar.Calendar(calendarEl, {
        initialView: 'dayGridMonth',
        locale: 'zh-tw',
        themeSystem: 'bootstrap5',
        headerToolbar: {
        left: 'prev,next today',
        center: 'title',
        right: 'dayGridMonth,listWeek'
        },

        // 👇 新增這一段：自訂按鈕的中文文字
        buttonText: {
        today: '今天',
        month: '月',
        week: '週',
        day: '日',
        list: '清單'
        },

        // 👇 新增這一段：全域修改行程方塊的顏色
        eventBackgroundColor: '#dc3545', // 方塊背景改為深紅色 (Bootstrap Danger 色)
        eventBorderColor: '#dc3545',     // 邊框也改成紅色
        eventTextColor: '#ffffff',       // 字體保持白色，這樣在紅底上最清楚

        events: '/Calendar/GetEvents',
        selectable: true,
        select: function(info) {
        document.getElementById('eventStart').value = info.startStr + "T09:00";
        var myModal = new bootstrap.Modal(document.getElementById('eventModal'));
        myModal.show();
        }
        });
        calendar.render();
        });

        // 後面的 saveEvent() 函數保持原樣不變...

        function saveEvent() {
        var title = document.getElementById('eventTitle').value;
        var start = document.getElementById('eventStart').value;

        if (!title) { alert("請輸入標題"); return; }

        // 使用 AJAX 將資料送到後端
        fetch('/Calendar/AddEvent', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: `title=${encodeURIComponent(title)}&start=${start}`
        })
        .then(res => res.json())
        .then(data => {
        if (data.success) {
        calendar.refetchEvents(); // 重新整理日曆
        bootstrap.Modal.getInstance(document.getElementById('eventModal')).hide();
        document.getElementById('eventTitle').value = ""; // 清空輸入框
        }
        });
        }
    </script>
}